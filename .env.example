# =============================================================================
# Phase 0 environment variables for credential-broker.
# Copy this to `.env.local` and fill in values as you set up each account.
# `.env.local` is gitignored — never commit secrets.
# Group ordering matches Phase 0 chores in `~/.claude/plans/wobbly-discovering-pascal.md`.
# =============================================================================


# -----------------------------------------------------------------------------
# Tier 1 — required before Sprint 3 can run end-to-end
# -----------------------------------------------------------------------------

# 0.1 Postgres
# v2 plan: docker postgres for local dev (Sprints 3-10), Neon for Sprint 11 cloud deploy.
# Local: `pnpm db:up` starts postgres:17 in docker; defaults below are the connection.
# Cloud (Sprint 11+): replace with Neon pooled / direct URLs from console.neon.tech.
DATABASE_URL=postgres://cb:cb@localhost:5433/cb_dev
DATABASE_DIRECT_URL=postgres://cb:cb@localhost:5433/cb_dev

# 0.2 Fly.io (Sprint 11 deploy only; no local env var.)
# Use `fly auth login` + `fly apps create cb-{pdp,control-plane}-prod` at deploy time.
# Secrets via `fly secrets set --app cb-pdp-prod KEY=value`.


# -----------------------------------------------------------------------------
# Tier 2 — Sprint 3 enriches if present, otherwise email/password fallback
# -----------------------------------------------------------------------------

# 0.4 WorkOS  (SSO/SCIM)
# Create at https://workos.com -> Dashboard -> API Keys
WORKOS_API_KEY=sk_test_xxx
WORKOS_CLIENT_ID=client_xxx
WORKOS_REDIRECT_URI=http://localhost:3000/auth/sso/callback

# 0.8 Sentry (already wired no-op without DSN — PDP works fine)
# Create at https://sentry.io -> create project (Node)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1


# -----------------------------------------------------------------------------
# Tier 3 — closer to relevant sprints; safe to leave blank now
# -----------------------------------------------------------------------------

# 0.3 Vercel (Sprint 6 dashboard) — uses `vercel link` + dashboard env vars; no local env

# 0.5 Knock (Sprint 9 step-up push)
# Empty = dev console fallback. Logger prints the /approve/:id deep link
# so a human can complete the flow without Knock provisioned.
KNOCK_API_KEY=
KNOCK_WORKFLOW_ID=step-up-request
STEPUP_DEFAULT_TTL_MS=60000
DASHBOARD_PUBLIC_URL=http://localhost:3000

# 0.6 Resend (Sprint 6/11 transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# 0.7 Stripe (Sprint 11 billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 0.9 GitHub OAuth (Sprint 5 OAuth bridge)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# 0.10 Slack app (Sprint 5 OAuth bridge)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# 0.11 Cloudflare R2 (Sprint 8 audit archive)
# Plan v2 picked R2 over AWS S3. Set the four R2_AUDIT_* values to enable the
# hourly Parquet archive worker. Leave blank in dev to keep it disabled —
# Postgres audit_events still records every event regardless.
R2_AUDIT_ENDPOINT=
R2_AUDIT_BUCKET=cb-audit-archive-dev
R2_AUDIT_ACCESS_KEY_ID=
R2_AUDIT_SECRET_ACCESS_KEY=

# Sprint 8.1 — push revocation. Comma-separated PDP webhook URLs the
# control plane POSTs to on revoke. Empty = polling-only fallback (5s sweep).
PDP_WEBHOOK_URLS=http://localhost:8787/v1/internal/refresh-revocations

# Sprint 8.3 / D-4 — audit root signing key. `pnpm gen-keys` writes these.
# AUDIT_VERIFY_KEY ships to npx @credential-broker/audit-verify.
AUDIT_SIGN_KEY=
AUDIT_VERIFY_KEY=
AUDIT_SIGNING_KEY_ID=


# -----------------------------------------------------------------------------
# Local dev defaults (no signup needed)
# -----------------------------------------------------------------------------

NODE_ENV=development
LOG_LEVEL=debug

# PDP
PORT=8787
CONTROL_PLANE_URL=http://localhost:8788
CONTROL_PLANE_SERVICE_TOKEN=dev-shared-token
POLICY_REFRESH_MS=60000
REVOCATION_REFRESH_MS=5000
# Sprint 8.2 — audit backend. `postgres` (default) or `jsonl` for the file fallback.
AUDIT_BACKEND=postgres
AUDIT_LOG_PATH=./audit.log
AUDIT_FLUSH_INTERVAL_MS=100
AUDIT_BATCH_SIZE_MAX=100

# OTel (set when Grafana Cloud is configured — Sprint 12 hardening)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=cb-pdp-dev


# -----------------------------------------------------------------------------
# Internal signing keys (generate via `pnpm exec tsx scripts/gen-keys.ts` once
# the script lands in Sprint 3; for now, you can leave blank)
# -----------------------------------------------------------------------------

CONTROL_PLANE_BUNDLE_SIGN_KEY=
CONTROL_PLANE_BUNDLE_VERIFY_KEY=


# -----------------------------------------------------------------------------
# P1: Dockerized dev stack (M1) — populated by `pnpm dev:setup`
# -----------------------------------------------------------------------------

# OAuth: at-rest token encryption + state-cookie HMAC. 64-hex / base64url.
OAUTH_TOKEN_ENCRYPTION_KEY=
OAUTH_STATE_SIGN_SECRET=
BETTER_AUTH_SECRET=
CONTROL_PLANE_SERVICE_TOKEN=

# Redis (rate-limit + chain-context fact cache)
REDIS_URL=redis://redis:6379

# In-cluster service URLs
CONTROL_PLANE_URL=http://control-plane:8788
PDP_URL=http://pdp:8787
CONTROL_PLANE_PUBLIC_URL=http://localhost:8788
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8788
NEXT_PUBLIC_PDP_URL=http://localhost:8787

# -----------------------------------------------------------------------------
# P1: M6 Telegram approval bot — leave blank to disable
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# -----------------------------------------------------------------------------
# P1: M7 chain-context LLM intent verification — flag-gated
# -----------------------------------------------------------------------------
INTENT_COHERENCE_ENABLED=false
INTENT_CHAIN_CONTEXT_ENABLED=false
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# P1: M8 egress proxy (observe-only) — flag-gated
# -----------------------------------------------------------------------------
EGRESS_PROXY_ENABLED=false
EGRESS_PROXY_PORT=25290

# -----------------------------------------------------------------------------
# Production deploy (Lane A) — fill before running preflight.sh on the VM.
# Local dev leaves these unset; the development defaults above remain in force.
# -----------------------------------------------------------------------------

# Neon Postgres (https://console.neon.tech). Use the POOLED URL for runtime and
# the DIRECT URL for `drizzle-kit migrate`. See infrastructure/neon/README.md.
# NEON_DATABASE_URL=postgres://nomos:...@ep-...-pooler.ap-southeast-1.aws.neon.tech/nomos?sslmode=require
# NEON_DATABASE_DIRECT_URL=postgres://nomos:...@ep-....ap-southeast-1.aws.neon.tech/nomos?sslmode=require

# Vercel dashboard URL (after `vercel domains add app.auto-nomos.com`)
# BETTER_AUTH_URL=https://app.auto-nomos.com
# NEXT_PUBLIC_CONTROL_PLANE_URL=https://api.auto-nomos.com
# NEXT_PUBLIC_PDP_URL=https://pdp.auto-nomos.com

# Crypto roots — generate ONCE per environment then store in a password vault.
# 32-byte XChaCha20 key for OAuth-at-rest:
#   openssl rand -hex 32
# Ed25519 keypair for audit-chain root signing:
#   pnpm --filter @auto-nomos/control-plane keygen:audit-roots
# SECRETBOX_KEY_HEX=
# AUDIT_SIGNING_PRIVATE_KEY_HEX=
# AUDIT_SIGNING_PUBLIC_KEY_HEX=

# R2 audit archive (Cloudflare R2; see infrastructure/r2/README.md)
# R2_AUDIT_BUCKET=nomos-audit-prod
# R2_AUDIT_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_AUDIT_ACCESS_KEY_ID=
# R2_AUDIT_SECRET_ACCESS_KEY=
