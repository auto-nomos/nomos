# Customer-edge PDP — copy to `.env.edge` and fill in.
#   docker compose -f infrastructure/docker/docker-compose.edge.yml \
#     --env-file infrastructure/docker/.env.edge up -d

# Where the SaaS control-plane lives.
CONTROL_PLANE_URL=https://api.auto-nomos.com

# Service token issued for this customer (Bearer on /v1/internal/*).
# Get from dashboard → settings → edge (or `curl -XPOST .../v1/service-tokens`
# once that surface lands). Treat as a long-lived secret; rotate yearly.
CONTROL_PLANE_SERVICE_TOKEN=

# Hex Ed25519 public key the control-plane signs policy bundles with.
# PDP refuses bundles that don't verify against this key — so a stolen
# service token alone can't push poisoned policies. Get from dashboard
# settings → edge → "bundle verify key".
CONTROL_PLANE_BUNDLE_VERIFY_KEY=

# Pin the customer set for offline operation. Comma-separated UUIDs.
# Leave empty to let the PDP discover from the control-plane every 60s.
PDP_CUSTOMER_IDS=

# Audit destination.
#   jsonl    — write to AUDIT_LOG_PATH on the mounted volume.
#   postgres — set DATABASE_URL below; use your own DB.
AUDIT_BACKEND=jsonl
AUDIT_LOG_PATH=/var/audit/pdp.log
# DATABASE_URL=postgres://user:pass@host:5432/cb

# Refresh cadence.
POLICY_REFRESH_MS=60000
REVOCATION_REFRESH_MS=5000

# Logs + telemetry.
LOG_LEVEL=info
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
