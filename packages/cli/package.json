{
  "name": "@auto-nomos/cli",
  "version": "0.0.2",
  "private": false,
  "description": "cb \u2014 credential-broker command-line: setup wizard, agent-client connectors, TUI, status checks.",
  "license": "MIT",
  "homepage": "https://github.com/auto-nomos/nomos/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/auto-nomos/nomos/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auto-nomos/nomos.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nomos": "./dist/bin.js",
    "cb": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bin.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@auto-nomos/adapters": "workspace:*",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
