{
  "name": "@credential-broker/schema-packs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./github": {
      "types": "./src/github/index.ts",
      "import": "./src/github/index.ts"
    },
    "./slack": {
      "types": "./src/slack/index.ts",
      "import": "./src/slack/index.ts"
    },
    "./google": {
      "types": "./src/google/index.ts",
      "import": "./src/google/index.ts"
    },
    "./notion": {
      "types": "./src/notion/index.ts",
      "import": "./src/notion/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@credential-broker/cedar": "workspace:*"
  },
  "devDependencies": {
    "@credential-broker/policy-builder": "workspace:*",
    "@types/node": "22.10.5",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
