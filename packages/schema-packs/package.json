{
  "name": "@auto-nomos/schema-packs",
  "version": "0.0.6",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./github": {
      "types": "./dist/github/index.d.ts",
      "import": "./dist/github/index.js"
    },
    "./slack": {
      "types": "./dist/slack/index.d.ts",
      "import": "./dist/slack/index.js"
    },
    "./google": {
      "types": "./dist/google/index.d.ts",
      "import": "./dist/google/index.js"
    },
    "./notion": {
      "types": "./dist/notion/index.d.ts",
      "import": "./dist/notion/index.js"
    },
    "./linear": {
      "types": "./dist/linear/index.d.ts",
      "import": "./dist/linear/index.js"
    },
    "./stripe": {
      "types": "./dist/stripe/index.d.ts",
      "import": "./dist/stripe/index.js"
    },
    "./google_calendar": {
      "types": "./dist/google_calendar/index.d.ts",
      "import": "./dist/google_calendar/index.js"
    },
    "./google_gmail": {
      "types": "./dist/google_gmail/index.d.ts",
      "import": "./dist/google_gmail/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@auto-nomos/cedar": "workspace:*",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@auto-nomos/policy-builder": "workspace:*",
    "@types/node": "22.10.5",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
