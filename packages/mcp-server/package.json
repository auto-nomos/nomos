{
  "name": "@auto-nomos/mcp-server",
  "version": "0.0.17",
  "private": false,
  "description": "Distributable MCP server backed by Credential Broker. Wire into Claude Desktop / Cursor; the OAuth tokens stay on the PDP.",
  "license": "MIT",
  "homepage": "https://github.com/auto-nomos/nomos/tree/main/packages/mcp-server#readme",
  "bugs": {
    "url": "https://github.com/auto-nomos/nomos/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auto-nomos/nomos.git",
    "directory": "packages/mcp-server"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "credential-broker-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bin.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@auto-nomos/adapters": "workspace:*",
    "@auto-nomos/schema-packs": "workspace:*",
    "@auto-nomos/sdk": "workspace:*",
    "@auto-nomos/shared-types": "workspace:*",
    "@modelcontextprotocol/sdk": "1.18.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
