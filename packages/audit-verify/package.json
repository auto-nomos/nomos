{
  "name": "@auto-nomos/audit-verify",
  "version": "0.0.2",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/auto-nomos/nomos/tree/main/packages/audit-verify#readme",
  "bugs": {
    "url": "https://github.com/auto-nomos/nomos/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auto-nomos/nomos.git",
    "directory": "packages/audit-verify"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "audit-verify": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@auto-nomos/crypto": "workspace:*",
    "@auto-nomos/shared-types": "workspace:*",
    "@auto-nomos/ucan": "workspace:*",
    "@noble/hashes": "1.6.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
