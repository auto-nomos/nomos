{
  "name": "credential-broker",
  "version": "0.0.0",
  "private": true,
  "description": "Agent Authorization Platform — capability layer for MCP. UCAN + Cedar authorization for AI agents.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:server": "pnpm --filter @auto-nomos/control-plane --filter @auto-nomos/pdp --filter @auto-nomos/core --filter @auto-nomos/cedar --filter @auto-nomos/crypto --filter @auto-nomos/ucan --filter @auto-nomos/shared-types --filter @auto-nomos/schema-packs --filter @auto-nomos/policy-builder --filter @auto-nomos/rbac --filter @auto-nomos/redaction --filter @auto-nomos/sdk --filter @auto-nomos/adapters --filter @auto-nomos/audit-verify build",
    "test": "turbo run test",
    "test:watch": "turbo run test -- --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "db:reset": "docker compose -f infrastructure/docker/docker-compose.yml down -v && docker compose -f infrastructure/docker/docker-compose.yml up -d postgres",
    "db:logs": "docker compose -f infrastructure/docker/docker-compose.yml logs -f postgres",
    "dev:setup": "docker compose -f infrastructure/docker/docker-compose.dev.yml --profile init run --rm setup-wizard && docker compose -f infrastructure/docker/docker-compose.dev.yml --profile init run --rm migrate",
    "dev:build": "docker compose -f infrastructure/docker/docker-compose.dev.yml build",
    "dev:up": "docker compose -f infrastructure/docker/docker-compose.dev.yml up",
    "dev:up:detach": "docker compose -f infrastructure/docker/docker-compose.dev.yml up -d",
    "dev:tunnel": "docker compose -f infrastructure/docker/docker-compose.dev.yml --profile tunnel up cloudflared",
    "dev:down": "docker compose -f infrastructure/docker/docker-compose.dev.yml down",
    "dev:reset": "docker compose -f infrastructure/docker/docker-compose.dev.yml down -v && rm -f .cb-setup-done",
    "dev:logs": "docker compose -f infrastructure/docker/docker-compose.dev.yml logs -f",
    "dev:ps": "docker compose -f infrastructure/docker/docker-compose.dev.yml ps",
    "dev:setup:host": "tsx scripts/setup-wizard.mts",
    "gen-keys": "tsx scripts/gen-keys.mts",
    "gen:oidc-keys": "tsx scripts/gen-oidc-issuer-keys.mts",
    "test:packs": "tsx scripts/pack-smoke.mts",
    "test:smoke": "tsx scripts/deploy-smoke.mts",
    "audit:extractors": "tsx scripts/audit-pack-extractor-coverage.mts",
    "audit:parity": "pnpm -F @auto-nomos/schema-packs parity",
    "verify": "pnpm typecheck && pnpm lint && pnpm audit:extractors && pnpm audit:parity && pnpm -w test",
    "tunnel": "bash scripts/dev-tunnel.sh",
    "e2e:sprint3": "tsx scripts/e2e-sprint3.mts",
    "e2e:sprint5": "tsx scripts/e2e-sprint5.mts",
    "demo": "tsx scripts/demo.mts",
    "demo:dynamic-scope": "tsx scripts/demo-dynamic-scope.mts",
    "demo:dynamic-scope-github": "tsx scripts/demo-dynamic-scope-github.mts",
    "demo:swarm": "tsx --env-file-if-exists=.env.swarm scripts/swarm-demo.mts",
    "swarm:up": "docker compose -f infrastructure/docker/swarm/docker-compose.yml up --build",
    "swarm:down": "docker compose -f infrastructure/docker/swarm/docker-compose.yml down -v",
    "sim:approve": "tsx --env-file-if-exists=.env.local scripts/simulate-approval.mts",
    "audit:smuggle": "tsx --env-file-if-exists=.env.local scripts/audit-content-update-smuggle.mts",
    "test:prod:fs:mutate": "tsx --env-file-if-exists=.env.local scripts/prod-fs-mutate.mts",
    "test:prod:ssh:mutate": "tsx --env-file-if-exists=.env.local scripts/prod-ssh-mutate.mts",
    "test:local:ssh:mutate": "tsx --env-file-if-exists=.env.local scripts/local-ssh-mutate.mts",
    "test:local:ssh:fixture": "bash scripts/setup-ssh-test-fixture.sh",
    "test:local:ssh:up": "docker compose -f infrastructure/docker/docker-compose.ssh-test.yml up -d",
    "test:local:ssh:down": "docker compose -f infrastructure/docker/docker-compose.ssh-test.yml down -v",
    "changeset": "changeset",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "overrides": {
      "zod": "^3.25.0"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/cli": "2.27.11",
    "@auto-nomos/adapters": "workspace:*",
    "@auto-nomos/control-plane": "workspace:*",
    "@auto-nomos/crypto": "workspace:*",
    "@auto-nomos/pdp": "workspace:*",
    "@auto-nomos/schema-packs": "workspace:*",
    "@auto-nomos/sdk": "workspace:*",
    "@auto-nomos/ucan": "workspace:*",
    "@hono/node-server": "1.13.7",
    "@noble/hashes": "1.7.0",
    "@trpc/client": "11.0.0",
    "@types/pg": "8.11.10",
    "@vitest/coverage-v8": "4.1.5",
    "drizzle-orm": "0.36.4",
    "husky": "9.1.7",
    "lint-staged": "17.0.2",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "tsx": "4.21.0",
    "turbo": "2.9.10",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
