# Path A — subprocess swarm demo. Copy to `.env.swarm` and fill in.
# Then run: `pnpm demo:swarm`

# Endpoints (use https://api.auto-nomos.com for prod; localhost for local stack).
NOMOS_CP_URL=http://localhost:8788
NOMOS_PDP_URL=http://localhost:8787

# API keys — issue one per agent at /app/agents/<id> and copy the cb_live_… here.
NOMOS_PLANNER_API_KEY=cb_live_xxx
NOMOS_RESEARCHER_API_KEY=cb_live_xxx
NOMOS_WRITER_API_KEY=cb_live_xxx

# Agent UUIDs — visible at /app/agents (right column).
NOMOS_RESEARCHER_AGENT_ID=00000000-0000-0000-0000-000000000000
NOMOS_WRITER_AGENT_ID=00000000-0000-0000-0000-000000000000

# Swarm rooted at planner — create at /app/swarms with planner as root.
NOMOS_SWARM_ID=00000000-0000-0000-0000-000000000000

# GitHub OAuth — connect once at /app/connections, copy the connection UUID.
NOMOS_OAUTH_CONNECTION_ID=00000000-0000-0000-0000-000000000000
NOMOS_GITHUB_OWNER=acme
NOMOS_GITHUB_REPO=test-repo

# Optional: 1 = writer attempts /github/issue/create (will hit step-up policy
# if your Cedar requires cosigner for writes). Default reads only.
# NOMOS_DEMO_WRITE=1
