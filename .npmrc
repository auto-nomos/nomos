save-exact=true
save-prefix=
strict-peer-dependencies=false
auto-install-peers=true
engine-strict=true
# Containers / non-TTY: do not prompt before purging node_modules when
# the manifest hash mismatches. Avoids ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY
# under docker compose where volume mounts mask the image's node_modules.
confirm-modules-purge=false

