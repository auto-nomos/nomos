{
  "name": "@auto-nomos/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./router-types": {
      "types": "./src/router-types.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx --env-file-if-exists=../../.env.local --watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "oidc-rotate": "tsx --env-file-if-exists=../../.env.local scripts/oidc-rotate.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@auto-nomos/cedar": "workspace:*",
    "@auto-nomos/core": "workspace:*",
    "@auto-nomos/crypto": "workspace:*",
    "@auto-nomos/policy-builder": "workspace:*",
    "@auto-nomos/rbac": "workspace:*",
    "@auto-nomos/schema-packs": "workspace:*",
    "@auto-nomos/shared-types": "workspace:*",
    "@auto-nomos/ucan": "workspace:*",
    "@aws-sdk/client-kms": "3.709.0",
    "@aws-sdk/client-s3": "3.700.0",
    "@aws-sdk/client-sts": "3.709.0",
    "@dsnp/parquetjs": "1.8.6",
    "@hono/node-server": "1.13.7",
    "@simplewebauthn/server": "13.3.0",
    "@trpc/server": "11.0.0",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.36.4",
    "hono": "4.6.14",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "pino-pretty": "13.0.0",
    "superjson": "2.2.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@auto-nomos/audit-verify": "workspace:*",
    "@trpc/client": "11.0.0",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "dotenv": "16.4.7",
    "drizzle-kit": "0.28.1",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
