{
  "name": "@credential-broker/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@credential-broker/cedar": "workspace:*",
    "@credential-broker/core": "workspace:*",
    "@credential-broker/crypto": "workspace:*",
    "@credential-broker/shared-types": "workspace:*",
    "@credential-broker/ucan": "workspace:*",
    "@hono/node-server": "1.13.7",
    "@trpc/server": "11.0.0",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.36.4",
    "hono": "4.6.14",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "pino-pretty": "13.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@trpc/client": "11.0.0",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "drizzle-kit": "0.28.1",
    "superjson": "2.2.1",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
