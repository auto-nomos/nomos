{
  "name": "@auto-nomos/egress-proxy",
  "version": "0.0.0",
  "private": true,
  "description": "M8 — observe-only HTTP CONNECT proxy. Logs agent egress to api.anthropic.com / api.openai.com; tunnels TCP. TLS-MITM with body inspection lands in P2.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx --env-file-if-exists=../../.env.local --watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "pino": "9.5.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
