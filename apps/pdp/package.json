{
  "name": "@auto-nomos/pdp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx --env-file-if-exists=../../.env.local --watch src/index.ts",
    "start": "node dist/index.js",
    "bench": "tsx bench/baseline.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@auto-nomos/cedar": "workspace:*",
    "@auto-nomos/core": "workspace:*",
    "@auto-nomos/crypto": "workspace:*",
    "@auto-nomos/schema-packs": "workspace:*",
    "@auto-nomos/shared-types": "workspace:*",
    "@auto-nomos/ucan": "workspace:*",
    "@hono/node-server": "1.13.7",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.52.0",
    "hono": "4.6.14",
    "node-ssh": "^13.2.1",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "pino-pretty": "13.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "autocannon": "^8.0.0",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vitest": "4.1.5"
  }
}
